# ── WhatsApp / Meta ───────────────────────────────────────────────────────────
# WhatsApp Business Phone Number ID (NOT the phone number itself)
PHONE_NUMBER_ID=your_phone_number_id

# Full URL to send WhatsApp messages
WHATSAPP_API_URL=https://graph.facebook.com/v19.0/your_phone_number_id/messages

# Meta / WhatsApp access token
META_ACCESS_TOKEN=your_meta_access_token
ACCESS_TOKEN=your_meta_access_token
WHATSAPP_API_VERSION=v22.0

# Webhook verification token (any secret string you choose)
VERIFY_TOKEN=your_verify_token

# ── S3 Media Storage ─────────────────────────────────────────────────────────
S3_BUCKET_NAME=your_s3_bucket_name
S3_PREFIX=whatsapp-media
AWS_REGION=ap-south-1

# ── Backend / Agent ───────────────────────────────────────────────────────────
# Your local or remote LLM agent endpoint
AGENT_URL=http://127.0.0.1:5000

# ── AI Provider API keys ──────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key
TOGETHER_API_KEY=your_together_api_key
LLAMA_API_KEY=your_llama_api_key

# ── LLM Provider Configuration ────────────────────────────────────────────────
# Which provider to use for text responses
# Options: "groq" | "openai"
# Auto-detected when not set:
#   → "groq"   if GROQ_API_KEY is present  (original default behaviour)
#   → "openai" otherwise
LLM_PROVIDER=groq

# Model name override — leave blank to use the provider's default
# groq default  : llama-3.1-8b-instant
# openai default: gpt-4o-mini
LLM_MODEL=

# Optional explicit model keys used by service code
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.1-8b-instant

# ── Business Card Extraction ─────────────────────────────────────────────────
# Python-first extraction for images:
# true  -> try local OCR/regex extraction first, then fallback to AI
# false -> directly use AI extraction
BUSINESS_CARD_PYTHON_FIRST=true

# Minimum populated fields required to accept Python extraction result.
# If extracted fields are below this threshold, AI fallback is used.
BUSINESS_CARD_MIN_FIELDS=3

# ── Speech-To-Text (STT) ─────────────────────────────────────────────────────
# Local Whisper model to load first in STT fallback chain.
# Options: tiny | base | small | medium | large
LOCAL_WHISPER_MODEL=base

# Cloud STT models used in fallback chain
OPENAI_STT_MODEL=gpt-4o-transcribe
GROQ_STT_MODEL=whisper-large-v3-turbo

# Optional STT accuracy tuning
# Examples for language: en, hi, en-IN, hi-IN (leave blank for auto-detect)
STT_LANGUAGE_HINT=

# Optional bias prompt for better recognition of domain words/names.
# Example: "customer names, Indian phone numbers, email addresses"
STT_PROMPT=

# ── TTS Provider Configuration ────────────────────────────────────────────────
# Which provider to use for text-to-speech
# Options: "google" | "openai"
# Auto-detected when not set:
#   → "google" if GOOGLE_APPLICATION_CREDENTIALS is present
#   → "openai" otherwise  (original default behaviour — OpenAI tts-1-hd)
TTS_PROVIDER=google

# Google Cloud TTS options (used when TTS_PROVIDER=google)
# Language code — leave blank to auto-detect from response text
# Options: "en-IN" | "hi-IN"
GOOGLE_TTS_LANGUAGE=en-IN

# WaveNet voice name — leave blank to auto-select from language
# en-IN options: en-IN-Wavenet-A, en-IN-Wavenet-B, en-IN-Wavenet-C, en-IN-Wavenet-D
# hi-IN options: hi-IN-Wavenet-A, hi-IN-Wavenet-B, hi-IN-Wavenet-C, hi-IN-Wavenet-D
GOOGLE_TTS_VOICE=en-IN-Wavenet-B

# OpenAI TTS options (used when TTS_PROVIDER=openai)
# Options: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=alloy

# ── Google Cloud Credentials ──────────────────────────────────────────────────
# Path to your Google Cloud service account JSON key file
# Required when TTS_PROVIDER=google
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json

# ── MongoDB Conversation State ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=whatsapp_bot
MONGO_COLLECTION_NAME=conversations

# ── Salesforce Sync ───────────────────────────────────────────────────────────
SALESFORCE_API_URL=https://your-salesforce-endpoint.example.com
SALESFORCE_COOKIE=
SALESFORCE_TIMEOUT_SECONDS=15
SALESFORCE_MAX_RETRIES=3
SALESFORCE_BACKOFF_SECONDS=1.0
# Optional path controls:
# - If SALESFORCE_API_URL already points to create endpoint, leave create path empty.
# - Update path supports {lead_id} placeholder.
SALESFORCE_CREATE_LEAD_PATH=
SALESFORCE_UPDATE_LEAD_PATH_TEMPLATE=/{lead_id}
